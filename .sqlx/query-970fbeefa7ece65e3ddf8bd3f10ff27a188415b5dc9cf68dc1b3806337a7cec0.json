{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            a.sender_id,\n            a.recipient_id,\n            su.name AS sender_name,\n            ru.name AS recipient_name\n        FROM assignments a\n        JOIN users su ON su.id = a.sender_id\n        JOIN users ru ON ru.id = a.recipient_id\n        WHERE a.season_id = $1\n        ",
